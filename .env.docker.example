# Docker Compose overrides for pilot deployment
# Copy relevant values into multiagentchat/.env before deploy.
# This file documents compose-specific settings — do not put secrets here.

# Backend pilot overrides (set in multiagentchat/.env):
# CREW_SKIP_SUPPORT_TASKS=0
# OTEL_ENABLED=1  (when using --profile observability)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Frontend is configured in docker-compose.yml:
# BACKEND_URL=http://backend:8000
