# Backend URL for Next.js Route Handlers (server-side proxy to FastAPI)
BACKEND_URL=http://127.0.0.1:8000

# Optional: browser-facing API base (default: same-origin /api via Route Handlers)
# NEXT_PUBLIC_API_BASE_URL=/api
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Playwright E2E (default dev server port 3099 — see playwright.config.ts)
# PLAYWRIGHT_PORT=3099
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3099

# Max time (ms) to wait for a crew run before showing a timeout error (default: 600000 = 10 min)
# NEXT_PUBLIC_MAX_POLL_DURATION_MS=600000
