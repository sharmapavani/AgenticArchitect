# Required
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Knowledge base (ChromaDB)
CHROMA_PATH=.chroma
KNOWLEDGE_FAC_DIR=knowledge/pdf_fac_data
KNOWLEDGE_INS_DIR=knowledge/pdf_ins_data

# Crew execution controls
CREW_MAX_ITER=12
CREW_MAX_RPM=10
LLM_TEMPERATURE=0.2
# DEV: set to 0 to run full nine-task pipeline (ticket/handoff/copilot)
CREW_SKIP_SUPPORT_TASKS=1

# ServiceNow (stub until integration epic)
SN_INSTANCE=
SN_USER=
SN_PASSWORD=
SN_GROUP_FACILITIES=CAI - Facilities Support
SN_GROUP_INSURERS=CAI - Insurers Support
SN_GROUP_PMS=CAI - PMS Support

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Chat audit (SQLite + MCP)
CHAT_AUDIT_ENABLED=1
CHAT_AUDIT_DB_PATH=./data/chat_audit.db
CHAT_AUDIT_AUTO_INIT=1

# Observability (OpenTelemetry)
OTEL_ENABLED=0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=multiagentchat
OTEL_METRIC_EXPORT_INTERVAL_MS=5000

# Per-run SQLite metrics rollup (run_metrics + run_step_metrics tables)
RUN_METRICS_ENABLED=1

# Optional model pricing override for cost metrics (JSON)
# METRICS_PRICING_JSON={"gpt-4o-mini":{"input_per_1m":0.15,"output_per_1m":0.60}}

# Optional Portkey gateway (LLM + embeddings; hierarchical trace_id from run_id)
# PORTKEY_API_KEY=
# PORTKEY_BASE_URL=https://api.portkey.ai/v1
